pipeline {
    agent any

    environment {
        // ============ 镜像配置 ============
        DOCKER_IMAGE     = 'vuln-target-app'
        DOCKER_TAG       = "${env.BUILD_NUMBER}"
        APP_TEST_PORT    = '18080'

        // ============ Harbor 配置（按你的环境修改） ============
        // Harbor 地址（不带 https://）
        HARBOR_URL       = '192.168.1.100'
        // Harbor 项目名（需要在 Harbor 中提前创建）
        HARBOR_PROJECT   = 'security-test'
        // Harbor 完整镜像路径
        HARBOR_IMAGE     = "${HARBOR_URL}/${HARBOR_PROJECT}/${DOCKER_IMAGE}"
        // Jenkins 中配置的 Harbor 凭据 ID
        HARBOR_CRED_ID   = 'harbor-credentials'
    }

    stages {
        // ========== 阶段 1：准备代码 ==========
        stage('准备代码') {
            steps {
                echo '📂 准备构建代码...'
                script {
                    sh '''
                        SOURCE_DIR="/var/jenkins_home/workspace/python-sdk-main/cicd/jenkins-pipeline"
                        if [ -d "${SOURCE_DIR}" ]; then
                            echo "✓ 找到源目录"
                            cp -r "${SOURCE_DIR}" ./build-context
                            ls -la ./build-context/
                        else
                            echo "✗ 源目录不存在: ${SOURCE_DIR}"
                            echo "  检查可用目录："
                            ls -la /var/jenkins_home/workspace/ || true
                            exit 1
                        fi
                    '''
                }
            }
        }

        // ========== 阶段 2：构建靶标镜像 ==========
        stage('构建靶标镜像') {
            steps {
                echo '🔨 构建容器安全测试靶标镜像...'
                dir('build-context') {
                    sh """
                        echo "Docker 版本:"
                        docker --version
                        echo ""
                        echo "开始构建镜像: ${DOCKER_IMAGE}:${DOCKER_TAG}"
                        docker build \
                            --no-cache \
                            -t ${DOCKER_IMAGE}:${DOCKER_TAG} \
                            -t ${DOCKER_IMAGE}:latest \
                            .
                        echo ""
                        echo "✓ 镜像构建完成"
                        docker images ${DOCKER_IMAGE}
                    """
                }
            }
        }

        // ========== 阶段 3：验证镜像 ==========
        stage('验证镜像') {
            steps {
                echo '🧪 启动容器验证靶标应用...'
                sh """
                    docker rm -f test-vuln-target 2>/dev/null || true

                    docker run --rm -d \
                        --name test-vuln-target \
                        -p ${APP_TEST_PORT}:8000 \
                        ${DOCKER_IMAGE}:${DOCKER_TAG}

                    echo "等待应用启动..."
                    sleep 5

                    echo "--- 健康检查 ---"
                    curl -fsS http://localhost:${APP_TEST_PORT}/health || echo "⚠ 健康检查失败"

                    echo ""
                    echo "--- 漏洞端点验证 ---"
                    curl -fsS http://localhost:${APP_TEST_PORT}/vuln/cmd?cmd=whoami || true
                    echo ""
                    curl -fsS http://localhost:${APP_TEST_PORT}/vuln/file?path=/etc/passwd | head -3 || true
                    echo ""

                    echo ""
                    echo "--- 恶意文件检查 ---"
                    docker exec test-vuln-target ls -la /var/www/html/ || true
                    docker exec test-vuln-target ls -la /tmp/.hidden/ || true
                    docker exec test-vuln-target ls -la /tmp/.miner/ || true

                    echo ""
                    echo "✓ 靶标验证完成"
                    docker stop test-vuln-target || true
                """
            }
        }

        // ========== 阶段 4：镜像安全信息（可选，供安全平台对比） ==========
        stage('安全扫描摘要') {
            steps {
                echo '📋 输出安全风险摘要...'
                sh """
                    echo "======================================"
                    echo "  容器安全测试靶标 - 风险清单"
                    echo "======================================"
                    echo ""
                    echo "🔴 高危 - 恶意文件："
                    echo "  - /var/www/html/shell.php        (PHP Webshell)"
                    echo "  - /var/www/html/cmd.jsp          (JSP Webshell)"
                    echo "  - /var/www/html/eval_shell.py    (Python Webshell)"
                    echo "  - /var/www/html/aspx_cmd.aspx    (ASPX Webshell)"
                    echo "  - /tmp/.hidden/reverse_shell.sh  (反弹 Shell)"
                    echo "  - /tmp/.hidden/bind_shell.py     (Bind Shell 后门)"
                    echo "  - /tmp/.miner/start_miner.sh     (挖矿脚本)"
                    echo "  - /tmp/.miner/config.json        (挖矿池配置)"
                    echo "  - /root/.cache/.sys/rootkit_loader.c (Rootkit)"
                    echo ""
                    echo "🔴 高危 - 危险配置："
                    echo "  - /root/.ssh/authorized_keys     (植入的后门公钥)"
                    echo "  - /etc/ssh/sshd_config           (允许 root 登录+空密码)"
                    echo "  - /etc/cron.d/malicious           (恶意定时任务)"
                    echo "  - /app/.env                       (泄露的凭据文件)"
                    echo ""
                    echo "🔴 高危 - 运行时风险："
                    echo "  - 以 root 用户运行"
                    echo "  - 硬编码 AWS/DB/Redis 密码到环境变量"
                    echo "  - 安装 nmap/netcat 等危险工具"
                    echo "  - 暴露端口 22(SSH) 和 31337(后门)"
                    echo "  - Web 应用含命令注入/文件读取/SSRF 漏洞"
                    echo ""
                    echo "======================================"
                """
            }
        }

        // ========== 阶段 5：推送到 Harbor ==========
        stage('推送到 Harbor') {
            steps {
                echo '🚀 推送镜像到 Harbor...'
                script {
                    // 使用 Jenkins 凭据登录 Harbor
                    withCredentials([
                        usernamePassword(
                            credentialsId: env.HARBOR_CRED_ID,
                            usernameVariable: 'HARBOR_USER',
                            passwordVariable: 'HARBOR_PASS'
                        )
                    ]) {
                        sh """
                            echo "登录 Harbor: ${HARBOR_URL}"
                            echo "\${HARBOR_PASS}" | docker login ${HARBOR_URL} -u "\${HARBOR_USER}" --password-stdin

                            echo ""
                            echo "打标签..."
                            docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${HARBOR_IMAGE}:${DOCKER_TAG}
                            docker tag ${DOCKER_IMAGE}:latest         ${HARBOR_IMAGE}:latest

                            echo ""
                            echo "推送镜像..."
                            docker push ${HARBOR_IMAGE}:${DOCKER_TAG}
                            docker push ${HARBOR_IMAGE}:latest

                            echo ""
                            echo "✓ 推送完成!"
                            echo "  ${HARBOR_IMAGE}:${DOCKER_TAG}"
                            echo "  ${HARBOR_IMAGE}:latest"
                        """
                    }
                }
            }
        }

        // ========== 阶段 6：清理 ==========
        stage('清理') {
            steps {
                echo '🧹 清理临时资源...'
                sh '''
                    docker rm -f test-vuln-target 2>/dev/null || true
                '''
            }
        }
    }

    post {
        success {
            echo """
            =============================================
            ✅ CI/CD 流水线执行成功！
            =============================================
            镜像名称: ${DOCKER_IMAGE}:${DOCKER_TAG}
            Harbor:   ${HARBOR_IMAGE}:${DOCKER_TAG}

            本地运行:
              docker run -d -p 8000:8000 ${DOCKER_IMAGE}:${DOCKER_TAG}

            从 Harbor 拉取:
              docker pull ${HARBOR_IMAGE}:${DOCKER_TAG}
            =============================================
            """
        }
        failure {
            echo '❌ 构建失败，请查看控制台输出排查原因。'
        }
        always {
            echo '流水线执行完毕。'
            sh 'rm -rf ${WORKSPACE}/* ${WORKSPACE}/.* 2>/dev/null || true'
        }
    }
}
